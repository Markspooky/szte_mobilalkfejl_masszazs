<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/glass_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/glass_card">

        <TextView
            android:id="@+id/tvAppointName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masszázs neve"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvAppointDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dátum: 2023-10-10"
            android:textColor="#B0FFFFFF"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvAppointTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Időpont: 14:00"
            android:textColor="#B0FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnRateAppoint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ÉRTÉKELÉS"
                android:textColor="@color/neon_green"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnDeleteAppoint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEMONDÁS"
                android:textColor="@android:color/holo_red_light"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>