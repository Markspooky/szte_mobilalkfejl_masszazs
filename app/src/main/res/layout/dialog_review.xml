<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Értékeld a szolgáltatást!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1.0"
        android:layout_gravity="center"
        android:progressTint="@color/neon_green"
        android:secondaryProgressTint="@color/neon_green"/>

    <EditText
        android:id="@+id/etReviewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Véleményed (opcionális)"
        android:textColorHint="#80000000"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:backgroundTint="@color/green_grad_start"/>

</LinearLayout>